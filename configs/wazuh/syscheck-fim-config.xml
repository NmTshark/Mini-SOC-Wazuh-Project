<!--
  Example Wazuh FIM configuration for a controlled Windows lab.
  Merge this block into the existing <ossec_config> configuration.
-->
<ossec_config>
  <syscheck>
    <disabled>no</disabled>
    <frequency>300</frequency>
    <scan_on_start>yes</scan_on_start>

    <!-- Monitor only the dedicated lab path to reduce noise. -->
    <directories check_all="yes"
                 realtime="yes"
                 report_changes="yes">C:\SOC-Lab</directories>

    <!-- Add environment-specific exclusions here after validation. -->
  </syscheck>
</ossec_config>

